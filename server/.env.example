# ── MONGODB ───────────────────────────────────────────────────────────────────
#
# OPTION A: MongoDB Atlas (cloud) — Standard URI (recommended over mongodb+srv)
# Atlas → Connect → Drivers → toggle "Standard connection string"
MONGODB_URI="mongodb://username:password@cluster0-shard-00-00.a76msbw.mongodb.net:27017,cluster0-shard-00-01.a76msbw.mongodb.net:27017,cluster0-shard-00-02.a76msbw.mongodb.net:27017/askmydocs?ssl=true&replicaSet=atlas-xxx&authSource=admin&retryWrites=true&w=majority"
#
# OPTION B: Local MongoDB (no SSL needed — easiest for development)
# Install from: mongodb.com/try/download/community  then run: mongod
# MONGODB_URI="mongodb://localhost:27017/askmydocs"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-64-char-random-hex-secret"

# ── AI APIs ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-your-key-here"
OPENAI_API_KEY="sk-your-key-here"

# ── CLOUDFLARE R2 ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="askmydocs-files"
R2_PUBLIC_URL="https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev"

# ── SERVER ────────────────────────────────────────────────────────────────────
CLIENT_URL="http://localhost:5173"
PORT=5000
